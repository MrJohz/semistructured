{
  "name": "semistructured",
  "version": "0.0.0",
  "description": "",
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "check": "tsc",
    "lint": "oxlint",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "test": "node --test src/**/*.test.ts",
    "ci": "npm run check && npm run lint && npm run fmt:check && npm test",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "latest"
  }
}
